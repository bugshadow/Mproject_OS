# ── Couleurs ANSI ──
export LC_ALL=C
export C_RESET="\e[0m"
export C_GREEN="\e[32m"
export C_RED="\e[31m"
export C_YELLOW="\e[33m"
export C_BLUE="\e[34m"
export C_CYAN="\e[36m"
export C_BRED="\e[1;31m"

# ── Variables Globales ──
# Configuration des repertoires par defaut
# Note: Le cahier des charges demande imperativement /var/log/blackbox
export LOG_DIR="/var/log/blackbox"
export SERVICE_NAME=""
export MODE=""
export PLAYBACK_DATE=""
export FLAG_SUBSHELL=false
export FLAG_FORK=false
export FLAG_THREAD=false
export FLAG_VERBOSE=false
export CUSTOM_LOG_DIR=""

# ── Inclusions Modulaires (Dossier src/) ──
source ./src/utils.sh
source ./src/mode_watch.sh
source ./src/mode_analyze.sh
source ./src/mode_playback.sh

# ── Fonction centralisee de gestion d'erreur (avec affichage de la doc) ──
die() {
    local code="$1"
    local msg="$2"
    
    # 1. On avertit silencieusement dans le log si possible
    log_event "ERROR" "CODE $code : $msg" 2>/dev/null
    
    # 2. Exigence du prof (section 3.2.3) : documentation explicative ET "similaire"
    # Nous utilisons display_error_help (condensee sans le grand ASCII) au lieu de display_help
    display_error_help
    
    # 3. Affichage de la boîte d'erreur TOUT EN BAS pour qu'elle reste visible
    echo -e "\n${C_BRED}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${C_RESET}" >&2
    echo -e "${C_BRED}┃ § ERREUR ${code} : ${msg}${C_RESET}" >&2
    echo -e "${C_BRED}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${C_RESET}\n" >&2
    
    exit "$code"
}

# ── Parse des options (Getopts complet - Fondation Dev 1) ──
parse_options() {
    while getopts ":hwap:sftl:rv" opt; do
        case $opt in
            h) display_help; exit 0 ;;
            w) MODE="watch" ;;
            a) MODE="analyze" ;;
            p) MODE="playback"; PLAYBACK_DATE="$OPTARG" ;;
            s) FLAG_SUBSHELL=true ;;
            f) FLAG_FORK=true ;;
            t) FLAG_THREAD=true ;;
            v) FLAG_VERBOSE=true; export FLAG_VERBOSE ;;
            l) CUSTOM_LOG_DIR="$OPTARG" ;;
            r) MODE="restore" ;;
            ?) die 100 "Option inconnue: -$OPTARG" ;;
        esac
    done
    shift $((OPTIND - 1))
    SERVICE_NAME="$1"
    export SERVICE_NAME
}

# ── Initialisation ──
init_environment() {
    if [ -n "$CUSTOM_LOG_DIR" ]; then
        LOG_DIR="$CUSTOM_LOG_DIR"
        export LOG_DIR
    fi
    
    # Creation du dossier de logs s'il n'existe pas
    if [ ! -d "$LOG_DIR" ]; then
        mkdir -p "$LOG_DIR" 2>/dev/null
        # Pour le mode multi-utilisateur, le dossier doit être accessible en ecriture
        chmod 777 "$LOG_DIR" 2>/dev/null
    fi

    # Fichier de log specifique
    export LOG_FILE="${LOG_DIR}/history.log"
    # S'assurer que le fichier est accessible en ecriture pour tous les utilisateurs surveilles
    [ ! -f "$LOG_FILE" ] && touch "$LOG_FILE" 2>/dev/null
    chmod 666 "$LOG_FILE" 2>/dev/null
    
    export ARCHIVE_DIR="$LOG_DIR/archives"
    
    # S'assurer que le dossier src est accessible a tous pour le sourcing du hook
    [ -d "src" ] && chmod -R 755 src 2>/dev/null
    
    if [ "$MODE" != "restore" ]; then
        # On tente de creer les dossiers (silencieusement si deja presents ou erreur de droits)
        mkdir -p "$LOG_DIR" "$ARCHIVE_DIR" 2>/dev/null
        # On prepare le fichier de log
        if [ ! -f "$LOG_FILE" ]; then
            touch "$LOG_FILE" 2>/dev/null
        fi
    fi
}

# ── Validation ──
validate() {
    [ "$MODE" = "restore" ] && return
    
    [ -z "$SERVICE_NAME" ] && die 101 "Parametre obligatoire manquant. Usage: blackbox [OPTIONS] <SERVICE_NAME>"
    
    if [ "$MODE" = "analyze" ] || [ "$MODE" = "watch" ]; then
        local log_path="/var/log/$SERVICE_NAME"
        # On ne bascule sur les logs de test QUE si l'utilisateur a specifie un dossier local (commence par ./)
        if [[ "$LOG_DIR" == ./* ]]; then
            log_path="./tests/sample_logs"
        fi
        
        # Test silencieux pour verifier si on a les droits d'ecriture dans le dossier de destination
        if [ ! -w "$LOG_FILE" ] || [ ! -d "$LOG_DIR" ]; then
             die 103 "Permission refusee. Vous n'avez pas le droit d'ecrire dans /var/log/blackbox.\n┃ Solution: Utilisez 'sudo' ou utilisez un dossier local avec l'option '-l ./var_local/log'"
        fi

        # Verification du repertoire source (Obligatoire pour Analyze, Optionnel pour Watch)
        if [ ! -d "$log_path" ] && [ ! -d "/var/log/$SERVICE_NAME" ]; then
            if [ "$MODE" = "analyze" ]; then
                die 102 "Repertoire source (Dossier de logs) introuvable pour le service '$SERVICE_NAME'"
            else
                log_event "WARN" "Repertoire source introuvable pour '$SERVICE_NAME'. La correlation automatique sera desactivee."
            fi
        fi
    fi

    if [ "$MODE" = "playback" ]; then
        [ ! -f "$LOG_FILE" ] && die 104 "Fichier history.log introuvable pour rejeu (mode -p)"
    fi
}

mode_restore() { 
    [ "$(id -u)" != "0" ] && die 103 "Tentative d'action critique (restore) sans les droits administrateur (root). Utilisez sudo !"
    rm -rf "$LOG_DIR"
    log_event "INFOS" "Environnement reinitialise avec succes"
    exit 0
}

# ── Dispatcher (Execution du bon mode) ──
run_mode() {
    [ -n "$MODE" ] && log_event "INFOS" "blackbox demarre — service: ${SERVICE_NAME:-N/A} — mode: $MODE"
    case "$MODE" in
        watch)    watch_main "$SERVICE_NAME" ;;
        analyze)  analyze_main "$SERVICE_NAME" ;;
        playback) playback_main "$SERVICE_NAME" "$PLAYBACK_DATE" ;;
        restore)  mode_restore ;;
        *) die 100 "Aucun mode principal specifie (-w, -a, -p, -r) ou option entree inconnu" ;;
    esac
}

# ── Point d'Entree Principal ──
main() {
    parse_options "$@"
    
    if [ -z "$MODE" ]; then
        display_help
        exit 0
    fi

    init_environment
    validate

    # Dev 3: Verification du helper C multithread (Option -t)
    if $FLAG_THREAD; then
        export COMPRESS_HELPER="./bin/compress_helper"
        if [ -x "$COMPRESS_HELPER" ]; then
            log_event "INFOS" "Option Thread activee — compress_helper detecte : $COMPRESS_HELPER"
        else
            log_event "WARN" "Option -t activee mais bin/compress_helper introuvable. Lancez 'make' pour compiler."
        fi
    fi

    if $FLAG_SUBSHELL; then
        log_event "INFOS" "Mode isole active (Subshell)."
        echo -e "${C_CYAN}PID parent: $$${C_RESET}"
        (
            export LOG_DIR FLAG_VERBOSE C_RESET C_CYAN C_RED C_GREEN C_YELLOW C_BRED LOG_FILE
            echo -e "${C_CYAN}PID sous-shell: $BASHPID${C_RESET}"
            run_mode
        )
    else
        run_mode
    fi
}

main "$@"
