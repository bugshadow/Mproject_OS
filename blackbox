# ── Couleurs ANSI ──
export LC_ALL=C
export C_RESET="\e[0m"
export C_GREEN="\e[32m"
export C_RED="\e[31m"
export C_YELLOW="\e[33m"
export C_BLUE="\e[34m"
export C_CYAN="\e[36m"
export C_BRED="\e[1;31m"

# ── Variables Globales ──
export LOG_DIR="/var/log/blackbox"
export SERVICE_NAME=""
export MODE=""
export PLAYBACK_DATE=""
export FLAG_SUBSHELL=false
export FLAG_FORK=false
export FLAG_THREAD=false
export FLAG_VERBOSE=false
export CUSTOM_LOG_DIR=""

# ── Inclusions Modulaires (Dossier src/) ──
source ./src/utils.sh
source ./src/mode_watch.sh
source ./src/mode_analyze.sh
source ./src/mode_playback.sh

# ── Fonction centralisée de gestion d'erreur (avec affichage de la doc) ──
die() {
    local code="$1"
    local msg="$2"
    
    # 1. On avertit silencieusement dans le log si possible
    log_event "ERROR" "CODE $code : $msg" 2>/dev/null
    
    # 2. Exigence du prof (section 3.2.3) : documentation explicative ET "similaire"
    # Nous utilisons display_error_help (condensée sans le grand ASCII) au lieu de display_help
    display_error_help
    
    # 3. Affichage de la boîte d'erreur TOUT EN BAS pour qu'elle reste visible
    echo -e "\n${C_BRED}┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓${C_RESET}" >&2
    echo -e "${C_BRED}┃ § ERREUR ${code} : ${msg}${C_RESET}" >&2
    echo -e "${C_BRED}┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛${C_RESET}\n" >&2
    
    exit "$code"
}

# ── Parse des options (Getopts complet - Fondation Dev 1) ──
parse_options() {
    while getopts ":hwap:sftl:rv" opt; do
        case $opt in
            h) display_help; exit 0 ;;
            w) MODE="watch" ;;
            a) MODE="analyze" ;;
            p) MODE="playback"; PLAYBACK_DATE="$OPTARG" ;;
            s) FLAG_SUBSHELL=true ;;
            f) FLAG_FORK=true ;;
            t) FLAG_THREAD=true ;;
            v) FLAG_VERBOSE=true; export FLAG_VERBOSE ;;
            l) CUSTOM_LOG_DIR="$OPTARG" ;;
            r) MODE="restore" ;;
            ?) die 100 "Option inconnue: -$OPTARG" ;;
        esac
    done
    shift $((OPTIND - 1))
    SERVICE_NAME="$1"
    export SERVICE_NAME
}

# ── Initialisation ──
init_environment() {
    if [ -n "$CUSTOM_LOG_DIR" ]; then
        LOG_DIR="$CUSTOM_LOG_DIR"
        export LOG_DIR
    fi
    export LOG_FILE="$LOG_DIR/history.log"
    export ARCHIVE_DIR="$LOG_DIR/archives"
    
    if [ "$MODE" != "restore" ]; then
        # On tente de créer les dossiers (silencieusement si déjà présents ou erreur de droits)
        mkdir -p "$LOG_DIR" "$ARCHIVE_DIR" 2>/dev/null
        # On prépare le fichier de log
        if [ ! -f "$LOG_FILE" ]; then
            touch "$LOG_FILE" 2>/dev/null
        fi
    fi
}

# ── Validation ──
validate() {
    [ "$MODE" = "restore" ] && return
    
    [ -z "$SERVICE_NAME" ] && die 101 "Paramètre obligatoire manquant. Usage: blackbox [OPTIONS] <SERVICE_NAME>"
    
    if [ "$MODE" = "analyze" ] || [ "$MODE" = "watch" ]; then
        local log_path="/var/log/$SERVICE_NAME"
        # On ne bascule sur les logs de test QUE si l'utilisateur a spécifié un dossier local (commence par ./)
        if [[ "$LOG_DIR" == ./* ]]; then
            log_path="./tests/sample_logs"
        fi
        
        # Test silencieux pour vérifier si on a les droits d'écriture dans le dossier de destination
        if [ ! -w "$LOG_FILE" ] || [ ! -d "$LOG_DIR" ]; then
             die 103 "Permission refusée. Vous n'avez pas le droit d'écrire dans /var/log/blackbox.\n┃ Solution: Utilisez 'sudo' ou utilisez un dossier local avec l'option '-l ./var_local/log'"
        fi

        # Vérification du répertoire source (Obligatoire pour Analyze, Optionnel pour Watch)
        if [ ! -d "$log_path" ] && [ ! -d "/var/log/$SERVICE_NAME" ]; then
            if [ "$MODE" = "analyze" ]; then
                die 102 "Répertoire source (Dossier de logs) introuvable pour le service '$SERVICE_NAME'"
            else
                log_event "WARN" "Répertoire source introuvable pour '$SERVICE_NAME'. La corrélation automatique sera désactivée."
            fi
        fi
    fi

    if [ "$MODE" = "playback" ]; then
        [ ! -f "$LOG_FILE" ] && die 104 "Fichier history.log introuvable pour rejeu (mode -p)"
    fi
}

mode_restore() { 
    [ "$(id -u)" != "0" ] && die 103 "Tentative d'action critique (restore) sans les droits administrateur (root). Utilisez sudo !"
    rm -rf "$LOG_DIR"
    log_event "INFOS" "Environnement réinitialisé avec succès"
    exit 0
}

# ── Dispatcher (Exécution du bon mode) ──
run_mode() {
    [ -n "$MODE" ] && log_event "INFOS" "blackbox démarré — service: ${SERVICE_NAME:-N/A} — mode: $MODE"
    case "$MODE" in
        watch)    watch_main "$SERVICE_NAME" ;;
        analyze)  analyze_main "$SERVICE_NAME" ;;
        playback) playback_main "$SERVICE_NAME" "$PLAYBACK_DATE" ;;
        restore)  mode_restore ;;
        *) die 100 "Aucun mode principal spécifié (-w, -a, -p, -r) ou option entrée inconnu" ;;
    esac
}

# ── Point d'Entrée Principal ──
main() {
    parse_options "$@"
    
    if [ -z "$MODE" ]; then
        display_help
        exit 0
    fi

    init_environment
    validate

    # TODO Dev 3: Intégration de compress_helper.c (Option Thread)
    if $FLAG_THREAD; then
        log_event "INFOS" "Option Thread activée. (En attente d'implémentation logique C par Dev 3)"
    fi

    if $FLAG_SUBSHELL; then
        log_event "INFOS" "Mode isolé activé (Subshell)."
        echo -e "${C_CYAN}PID parent: $$${C_RESET}"
        (
            export LOG_DIR FLAG_VERBOSE C_RESET C_CYAN C_RED C_GREEN C_YELLOW C_BRED LOG_FILE
            echo -e "${C_CYAN}PID sous-shell: $BASHPID${C_RESET}"
            run_mode
        )
    else
        run_mode
    fi
}

main "$@"